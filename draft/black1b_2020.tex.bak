%whose invariant distribution {\it is\/} the posterior, then iterates the Markov chain to convergence.
\auth{Eichenbaum, Martin} \auth{Christiano, Lawrence J.}
\auth{Burnside, Craig} \auth{Rebelo, Sergio}%
\auth{Canova, Fabio}%
\auth{DeJong, David}%
\auth{Dave, Chetan}%
