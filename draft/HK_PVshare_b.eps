[0.6 0 0 0.6 0 0] CT
1 GC
N
0 0 700 525 re
f
GR
GS
[0.48 0 0 0.48018 0 62.90397] CT
[1 0 0 1 0 0] CT
N
0 -131 M
875 -131 L
875 525 L
0 525 L
0 -131 L
cp
clip
GS
0 0 translate
700 525 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceGray setcolorspace
<<
  /ImageType 1
  /Decode [0 1]
  /DataSource Data
  /Height 525
  /ImageMatrix [700 0 0 525 0 0]
  /Width 700
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
